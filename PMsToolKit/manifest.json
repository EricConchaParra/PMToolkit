{
    "manifest_version": 3,
    "name": "PMsToolKit",
    "version": "2.0",
    "description": "Custom toolkit to enhance project management workflows on the web. Created by EricConcha.",
    "permissions": [
        "clipboardWrite",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://*.atlassian.net/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.atlassian.net/*"
            ],
            "js": [
                "jira-tools.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "48": "icon.png"
    }
}