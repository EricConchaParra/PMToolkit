{
    "manifest_version": 3,
    "name": "PMsToolKit",
    "version": "0.11.0",
    "description": "Personal toolkit to enhance project management workflows on Jira Cloud. (Beta v0.11.0)",
    "permissions": [
        "clipboardWrite",
        "storage",
        "tabs",
        "alarms",
        "notifications"
    ],
    "host_permissions": [
        "https://*.atlassian.net/*",
        "https://*.zoom.us/*",
        "https://api.github.com/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "index.html",
        "default_icon": "assets/icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.atlassian.net/*"
            ],
            "exclude_matches": [
                "https://*.atlassian.net/wiki/*"
            ],
            "js": [
                "content-loader.js"
            ],
            "css": [
                "assets/jira-styles.css"
            ],
            "run_at": "document_idle",
            "all_frames": true,
            "match_about_blank": true
        },
        {
            "matches": [
                "https://*.zoom.us/rec/play/*",
                "https://*.zoom.us/rec/share/*"
            ],
            "js": [
                "zoom-loader.js"
            ],
            "css": [
                "assets/zoom-content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "content.js",
                "zoom-content.js",
                "background.js",
                "src/pages/exporter/index.html",
                "exporter.js",
                "src/pages/analytics/index.html",
                "analytics.js"
            ],
            "matches": [
                "https://*.atlassian.net/*",
                "https://*.zoom.us/*",
                "<all_urls>"
            ]
        }
    ]
}
